{
  "name": "aria-tts",
  "version": "1.0.0",
  "description": "Aria — text-to-speech web app powered by the OpenAI API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && tsc --project tsconfig.frontend.json && cp src/public/index.html src/public/style.css dist/public/ && cp src/db/schema.sql dist/db/",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "tts",
    "openai",
    "text-to-speech"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "music-metadata": "^11.12.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
